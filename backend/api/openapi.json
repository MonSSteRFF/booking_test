		"/auth/login": {
			"post": {
				"operationId": "AuthController_login",
				"parameters": [],
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/LoginDto"
							}
						}
					}
				},
				"responses": {
					"200": {
						"description": "JWT token",
						"content": {
							"application/json": {
								"schema": {
									"properties": {
