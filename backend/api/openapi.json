  "info": {
    "title": "Slot Booking API",
    "description": "Мини-система бронирования слотов (CQRS: Mongo + ClickHouse)",
    "version": "3.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "SortingDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Field to sort by"
          },
          "desc": {
            "type": "boolean",
            "description": "Sort direction"
          }
        },
        "required": [
          "id"
        ]
      },
      "ColumnFilterDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Filter field ID"
          },
          "value": {
            "type": "string",
            "description": "Filter value(s)"
          },
          "filterFn": {
            "type": "string",
            "description": "Filter function (in, contains)"
          }
        },
        "required": [
          "id",
          "value",
          "filterFn"
        ]
      },
      "DateRangeDto": {
        "type": "object",
        "properties": {
          "from": {
            "type": "number",
            "description": "Start date (Unix timestamp in seconds)"
          },
          "to": {
            "type": "number",
            "description": "End date (Unix timestamp in seconds)"
          },
          "field": {
            "type": "string",
            "description": "Date field name"
          },
          "timezone": {
            "type": "string",
            "description": "Timezone"
          }
        },
        "required": [
          "from",
          "to",
          "field"
        ]
      },
      "FetchManySlotsDto": {
        "type": "object",
        "properties": {
          "pageIndex": {
            "type": "number",
            "description": "Page index (0-based)"
          },
          "pageSize": {
            "type": "number",
            "description": "Page size"
          },
          "sorting": {
            "description": "Sorting configuration",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SortingDto"
            }
          },
          "columnFilters": {
            "description": "Column filters",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ColumnFilterDto"
            }
          },
          "dateRange": {
            "description": "Date range filter",
            "allOf": [
              {
                "$ref": "#/components/schemas/DateRangeDto"
              }
            ]
          }
        },
        "required": [
          "pageIndex",
          "pageSize",
          "sorting",
          "columnFilters"
        ]
      },
      "Slot": {
        "type": "object",
        "properties": {
          "mongoId": {
            "type": "string",
            "description": "MongoDB document ID"
          },
          "title": {
            "type": "string",
            "description": "Slot title",
            "maxLength": 200
          },
          "startsAt": {
            "type": "number",
            "description": "Slot start time (Unix timestamp in seconds)"
          },
          "capacity": {
            "type": "number",
            "description": "Maximum capacity",
            "minimum": 1,
            "maximum": 1000
          },
          "bookedCount": {
            "type": "number",
            "description": "Current booked count",
            "minimum": 0
          },
          "isActive": {
            "type": "boolean",
            "description": "Whether slot is active"
          },
          "createdAt": {
            "type": "number",
            "description": "Creation timestamp (Unix timestamp in seconds)"
          },
          "updatedAt": {
            "type": "number",
            "description": "Last update timestamp (Unix timestamp in seconds)"
          }
        },
        "required": [
          "mongoId",
          "title",
          "startsAt",
          "capacity",
          "bookedCount",
          "isActive",
          "createdAt",
          "updatedAt"
        ]
      },
      "SlotsListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Slot"
            }
          },
          "totalCount": {
            "type": "number"
          }
        },
        "required": [
          "data",
          "totalCount"
        ]
      },
      "CreateSlotDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "Slot title",
            "maxLength": 200
          },
          "startsAt": {
            "type": "number",
            "description": "Slot start time (Unix timestamp in seconds)"
          },
          "capacity": {
            "type": "number",
            "description": "Maximum capacity",
            "minimum": 1,
            "maximum": 1000
          }
        },
        "required": [
          "title",
          "startsAt",
          "capacity"
        ]
      },
      "UpdateSlotDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "Slot title",
            "maxLength": 200
          },
          "startsAt": {
            "type": "number",
            "description": "Slot start time (Unix timestamp in seconds)"
          },
          "capacity": {
            "type": "number",
            "description": "Maximum capacity",
            "minimum": 1,
            "maximum": 1000
          }
        }
      },
      "CreateBookingDto": {
        "type": "object",
        "properties": {
          "clientName": {
            "type": "string",
            "description": "Client name",
            "maxLength": 200
          },
          "clientEmail": {
            "type": "string",
            "description": "Client email"
          }
        },
        "required": [
          "clientName",
          "clientEmail"
        ]
      },
      "Booking": {
        "type": "object",
        "properties": {
          "mongoId": {
            "type": "string",
            "description": "MongoDB document ID"
          },
          "slotId": {
            "type": "string",
            "description": "Slot ID reference"
          },
          "slotTitle": {
            "type": "string",
            "description": "Denormalized slot title at booking time"
          },
          "slotStartsAt": {
            "type": "number",
            "description": "Denormalized slot start time at booking time (Unix timestamp in seconds)"
          },
          "clientName": {
            "type": "string",
            "description": "Client name",
            "maxLength": 200
          },
          "clientEmail": {
            "type": "string",
            "description": "Client email (lowercased)"
          },
          "status": {
            "type": "string",
            "description": "Booking status",
            "enum": [
              "ACTIVE",
              "CANCELLED"
            ]
          },
          "createdAt": {
            "type": "number",
            "description": "Creation timestamp (Unix timestamp in seconds)"
          },
          "updatedAt": {
            "type": "number",
            "description": "Last update timestamp (Unix timestamp in seconds)"
          }
        },
        "required": [
          "mongoId",
          "slotId",
          "slotTitle",
          "slotStartsAt",
          "clientName",
          "clientEmail",
          "status",
          "createdAt",
          "updatedAt"
        ]
      },
      "FetchManyBookingsDto": {
        "type": "object",
        "properties": {
          "pageIndex": {
            "type": "number",
            "description": "Page index (0-based)"
          },
          "pageSize": {
            "type": "number",
            "description": "Page size"
          },
          "sorting": {
            "description": "Sorting configuration",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SortingDto"
            }
          },
          "columnFilters": {
            "description": "Column filters",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ColumnFilterDto"
            }
          },
          "dateRange": {
            "description": "Date range filter",
            "allOf": [
              {
                "$ref": "#/components/schemas/DateRangeDto"
              }
            ]
          }
        },
        "required": [
          "pageIndex",
          "pageSize",
          "sorting",
          "columnFilters"
        ]
      },
      "BookingsListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Booking"
            }
          },
          "totalCount": {
            "type": "number"
          }
        },
        "required": [
          "data",
          "totalCount"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "login": {
            "type": "string",
            "description": "Admin login"
          },
          "password": {
            "type": "string",
            "description": "Admin password"
          }
        },
        "required": [
          "login",
          "password"
        ]
      }
    }
  }
}